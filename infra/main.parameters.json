      "aiProjectDeploymentsJson": {
        "value": "[{\"name\":\"gpt-5.4\",\"model\":{\"name\":\"gpt-5.4\",\"format\":\"OpenAI\",\"version\":\"2026-03-05\"},\"sku\":{\"name\":\"DataZoneStandard\",\"capacity\":100}},{\"name\":\"gpt-5.4-mini\",\"model\":{\"name\":\"gpt-5.4-mini\",\"format\":\"OpenAI\",\"version\":\"2026-03-17\"},\"sku\":{\"name\":\"DataZoneStandard\",\"capacity\":50}}]"
      },
      "foundryModelDeploymentName": {
        "value": "gpt-5.4"
